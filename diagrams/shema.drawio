<mxfile host="app.diagrams.net">
  <diagram name="Sanji Homelab - Network V1">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="850">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- INTERNET -->
        <mxCell id="2" value="Internet (Cloud)" style="shape=cloud;whiteSpace=wrap;html=1;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="450" y="20" width="120" height="80" as="geometry"/>
        </mxCell>

        <!-- ROUTER -->
        <mxCell id="3" value="RTR-01&#xa;WR802N (WISP)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="450" y="140" width="120" height="60" as="geometry"/>
        </mxCell>

        <!-- SWITCH -->
        <mxCell id="4" value="SW-01&#xa;TP-Link Omada" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="450" y="260" width="120" height="60" as="geometry"/>
        </mxCell>

        <!-- FIREWALL -->
        <mxCell id="5" value="FW-01&#xa;Netgear FVS338" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;" vertex="1" parent="1">
          <mxGeometry x="200" y="360" width="140" height="60" as="geometry"/>
        </mxCell>

        <!-- PROXMOX -->
        <mxCell id="6" value="SRV-HV01&#xa;Proxmox VE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;" vertex="1" parent="1">
          <mxGeometry x="450" y="360" width="140" height="60" as="geometry"/>
        </mxCell>

        <!-- RASPBERRY PI -->
        <mxCell id="7" value="SRV-PI01&#xa;Raspberry Pi" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;" vertex="1" parent="1">
          <mxGeometry x="700" y="360" width="140" height="60" as="geometry"/>
        </mxCell>

        <!-- LINKS -->
        <mxCell id="8" edge="1" parent="1" source="2" target="3" style="endArrow=block;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="9" edge="1" parent="1" source="3" target="4" style="endArrow=block;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="10" edge="1" parent="1" source="4" target="5" style="endArrow=block;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="11" edge="1" parent="1" source="4" target="6" style="endArrow=block;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="12" edge="1" parent="1" source="4" target="7" style="endArrow=block;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>